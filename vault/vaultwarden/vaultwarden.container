[Unit]
Description=Vaultwarden
After=network-online.target

[Container]
Image=docker.io/vaultwarden/server:latest
PublishPort=127.0.0.1:3004:80
Volume=%h/volumes/vaultwarden/data:/data
EnvironmentFile=%h/volumes/vaultwarden/.env
Network=caddy.network
AutoUpdate=registry

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
