[Unit]
Description=V2Ray Proxy
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=v2ray
Image=docker.io/v2fly/v2fly-core:latest
PublishPort=1080:1080/tcp
PublishPort=1080:1080/udp
PublishPort=8080:8080
Volume=%h/.config/containers/systemd/configs/v2ray/config.json:/etc/v2fly/config.json:ro
AutoUpdate=registry

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
