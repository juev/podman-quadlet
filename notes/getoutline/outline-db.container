[Unit]
Description=Outline PostgreSQL
After=network-online.target

[Container]
ContainerName=outline-db
Image=docker.io/library/postgres:16-alpine
Volume=%h/volumes/outline/database:/var/lib/postgresql/data
EnvironmentFile=%h/volumes/outline/.env
Network=outline.network
HealthCmd=pg_isready -U outline

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
