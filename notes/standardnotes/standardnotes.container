[Unit]
Description=Standard Notes Server
After=network-online.target
After=standardnotes-db.service
After=standardnotes-redis.service
After=standardnotes-localstack.service

[Container]
ContainerName=standardnotes
Image=docker.io/standardnotes/server:latest
Volume=%h/volumes/standardnotes/logs:/var/lib/server/logs
Volume=%h/volumes/standardnotes/uploads:/opt/server/packages/files/dist/uploads
EnvironmentFile=%h/volumes/standardnotes/.env
Network=caddy.network
Network=standardnotes.network

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
