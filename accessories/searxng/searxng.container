[Unit]
Description=SearXNG metasearch engine
After=searxng-valkey.service

[Container]
ContainerName=searxng
Image=docker.io/searxng/searxng:latest
Volume=%h/volumes/searxng/config:/etc/searxng:Z
Environment=SEARXNG_BASE_URL=https://search.example.org/
Environment=UWSGI_WORKERS=4
Environment=UWSGI_THREADS=4
UserNS=keep-id:uid=977,gid=977
Network=caddy.network
Network=searxng_cache.network
DNS=1.1.1.1
DNS=8.8.8.8
AutoUpdate=registry

[Service]
Restart=always

[Install]
WantedBy=default.target
