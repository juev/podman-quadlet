[Unit]
Description=Cloudflare Tunnel
After=network-online.target

[Container]
ContainerName=cloudflared
Image=docker.io/cloudflare/cloudflared:latest
Exec=tunnel run
EnvironmentFile=%h/volumes/cloudflared/.env
Network=host
ReadOnly=true
AutoUpdate=registry

[Service]
Restart=always

[Install]
WantedBy=default.target
