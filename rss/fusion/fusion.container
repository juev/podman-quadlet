[Unit]
Description=Fusion RSS Reader
After=network-online.target

[Container]
ContainerName=fusion
Image=docker.io/rook1e404/fusion:latest
Volume=%h/volumes/fusion/data:/data
EnvironmentFile=%h/volumes/fusion/.env
Network=caddy.network
AutoUpdate=registry

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=default.target
